# Alpaca API credentials (paper trading) — https://app.alpaca.markets
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here

# Optional: Claude-scored news sentiment (keyword heuristic without it)
ANTHROPIC_API_KEY=
SENTIMENT_MODEL=claude-opus-4-8

# Optional: LLM strategy analyst (cloud Ollama, OpenAI-compatible API)
# Toggle on/off from the dashboard — off by default.
# For Ollama Cloud: base URL = https://ollama.com/v1, get API key at
# https://ollama.com/settings/keys
ANALYST_OLLAMA_BASE_URL=
ANALYST_OLLAMA_API_KEY=
ANALYST_OLLAMA_MODEL=deepseek-r1
ANALYST_TRADE_REVIEW_INTERVAL_HOURS=4
ANALYST_TRADE_LOOKBACK=50

# Trading configuration
TRADING_SYMBOLS=ALL
WATCHLIST_SIZE=50
POSITION_SIZE_USD=500
RISK_PER_TRADE_USD=20
COOLDOWN_MINUTES=30
MAX_POSITIONS=5
DAILY_STOP_LOSS=100
MIN_PRICE_USD=5
POLL_INTERVAL_SECONDS=60

# Dashboard → backend debug API (actions only: resume engine, run optimizer).
# The compose default reaches the backend container over the internal network.
BACKEND_API_URL=http://trading_backend:8000
